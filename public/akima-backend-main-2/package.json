{
  "name": "akima-backend",
  "version": "1.0.0",
  "description": "High-performance backend API for music streaming utilizing yt-dlp",
  "main": "src/server.js",
  "scripts": {
    "start": "node --env-file=.env src/server.js",
    "dev": "node --env-file=.env src/server.js"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@supabase/supabase-js": "^2.100.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "spotify-web-api-node": "^5.0.2",
    "yt-search": "^2.13.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "javascript-obfuscator": "^5.4.1",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "ignore": [
      "node:sqlite"
    ]
  }
}
